        "additionalFields": {
          "queryParams": "={{ [ $('Webhook Reception').item.json.body.title, $('Company UPSERT').item.json.id, $('Webhook Reception').item.json.body.description, $('Webhook Reception').item.json.body.description, $('Webhook Reception').item.json.body.location, $('Webhook Reception').item.json.body.url, $('Webhook Reception').item.json.body.easyApply, $('Validation & Hash Generator').item.json.jobHash, $json.shouldApply ? 'READY' : 'SKIPPED', $json.calculatedScore ] }}"
        }
      },
