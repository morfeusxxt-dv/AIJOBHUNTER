    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT name, file_path FROM resumes ORDER BY generated_at DESC LIMIT 1;"
      },
      "id": "node-load-resume",
      "name": "Load Resume Markdown Content",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 1,
      "position": [
        1900,
        400
      ],
      "onError": "retry",
      "retryOnFail": true,
      "maxRetries": 3
    },

    {
      "parameters": {
        "jsCode": "const text = $('Webhook Reception').item.json.body.description.toLowerCase();\nconst synonyms = {\n  'javascript': ['js', 'javascript', 'reactjs', 'node', 'nodejs', 'react'],\n  'python': ['python', 'fastapi', 'django', 'flask'],\n  'java': ['java', 'spring', 'spring boot'],\n  'aws': ['aws', 'amazon web services', 'ec2', 's3'],\n  'docker': ['docker', 'kubernetes', 'k8s']\n};\n\nconst found = [];\nfor (const [key, list] of Object.entries(synonyms)) {\n  for (const syn of list) {\n    if (text.includes(syn)) {\n      found.push(key.toUpperCase());\n      break;\n    }\n  }\n}\n\nitems[0].json.skillsExtracted = found;\nreturn items;"
      },
      "id": "node-skills-extractor",
      "name": "Skills Extractor & Normalizer",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2300,
        400
      ]
    },
    {
      "parameters": {
        "jsCode": "const job = $('Webhook Reception').item.json.body;\nconst cv = $('Load Resume Markdown Content').item.json.file_path || 'Master resume markdown content';\nconst settings = $('Read Configuration Settings').item.json;\nconst skills = $json.skillsExtracted || [];\n\nitems[0].json.dynamicPrompt = `You are a technical ATS screener.\nAnalyze the following job description:\nTitle: ${job.title}\nCompany: ${job.company}\nDescription: ${job.description}\n\nCandidate Master CV:\n${cv}\n\nIdentified Tech Skills: ${skills.join(', ')}\nTarget score: ${settings.score_min}\n\nReturn JSON.`;\nreturn items;"
      },
      "id": "node-prompt-builder",
      "name": "Prompt Builder",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2500,
        400
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $json.dynamicPrompt }}",
        "options": {
          "systemMessage": "You are a precise ATS scoring engine. You MUST output structured JSON."
        }
      },
      "id": "node-enterprise-agent",
      "name": "Enterprise AI Agent",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1,
      "position": [
        2700,
        400
      ],
      "onError": "retry",
      "retryOnFail": true,
      "maxRetries": 3
    },
    {
      "parameters": {
        "jsonSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"highlightSkills\": { \"type\": \"array\", \"items\": { \"type\": \"string\" } },\n    \"missingSkills\": { \"type\": \"array\", \"items\": { \"type\": \"string\" } },\n    \"resumeMarkdown\": { \"type\": \"string\" },\n    \"coverLetter\": { \"type\": \"string\" },\n    \"answers\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"about\": { \"type\": \"string\" },\n        \"why\": { \"type\": \"string\" },\n        \"salary\": { \"type\": \"string\" },\n        \"experienceYears\": { \"type\": \"string\" },\n        \"remotePreference\": { \"type\": \"string\" }\n      },\n      \"required\": [\"about\", \"why\", \"salary\"]\n    }\n  },\n  \"required\": [\"highlightSkills\", \"missingSkills\", \"resumeMarkdown\", \"coverLetter\", \"answers\"]\n}"
      },
      "id": "node-structured-parser",
      "name": "Structured Output Parser",
      "type": "@n8n/n8n-nodes-langchain.outputParserStructured",
      "typeVersion": 1,
      "position": [
        2900,
        550
      ]
    },
    {
      "parameters": {
        "model": "gpt-4o",
        "options": {
          "temperature": 0.2,
          "timeout": 120000
        }
      },
      "id": "node-openai-model",
      "name": "OpenAI Chat Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
      "typeVersion": 1,
      "position": [
        2800,
        550
      ]
    },
    {
      "parameters": {
        "jsCode": "const data = items[0].json;\nconst highlightCount = (data.highlightSkills || []).length;\nconst missingCount = (data.missingSkills || []).length;\n\n// Deterministic Score Calculation considering multi-category weights\nlet score = 100;\nif (highlightCount + missingCount > 0) {\n  score = Math.round((highlightCount / (highlightCount + missingCount)) * 100);\n}\n\nconst minScore = $('Read Configuration Settings').item.json.score_min || 90;\nconst apply = score >= minScore;\n\nitems[0].json.calculatedScore = score;\nitems[0].json.shouldApply = apply;\nreturn items;"
      },
      "id": "node-score-engine",
      "name": "Score Engine",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3100,
        400
      ]
    },
    {
      "parameters": {
        "jsCode": "const md = items[0].json.resumeMarkdown || '';\n// Convert markdown to clean HTML and structured representation\nlet html = md\n  .replace(/# (.*)/g, '<h1>$1</h1>')\n  .replace(/## (.*)/g, '<h2>$1</h2>')\n  .replace(/\\*\\*(.*)\\*\\*/g, '<strong>$1</strong>')\n  .replace(/\\*(.*)\\*/g, '<em>$1</em>')\n  .replace(/\\n/g, '<br/>');\n\nitems[0].json.resumeHtml = `<html><body>${html}</body></html>`;\n// Mock PDF creation path representation\nitems[0].json.resumePdfPath = `/app/data/resumes/CV_${Date.now()}.pdf`;\nreturn items;"
      },
      "id": "node-cv-formatter",
      "name": "Format CV HTML",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3300,
        400
      ]
    },
