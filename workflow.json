        "query": "INSERT INTO logs (service, message, level, details, created_at) VALUES ('n8n_error', $1, 'ERROR', $2, NOW());",
        "additionalFields": {
          "queryParams": "={{ [ $json.execution.error.message, JSON.stringify($json.execution) ] }}"
        }
      },
      "id": "node-save-error-log-26",
      "name": "Save Error Log DB",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 1,
      "position": [
        300,
        800
      ]
    }
