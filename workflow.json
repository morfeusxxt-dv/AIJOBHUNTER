        "responseBody": "={\n  \"apply\": true,\n  \"score\": {{ $json.score }},\n  \"resumeMarkdown\": \"{{ $json.resume_markdown || '' }}\",\n  \"resumeHtml\": \"\",\n  \"resumePdf\": \"\",\n  \"coverLetter\": \"{{ $json.cover_letter || '' }}\",\n  \"answers\": {\n    \"about\": \"Loaded from Cache\",\n    \"why\": \"Loaded from Cache\",\n    \"salary\": \"Negotiable\"\n  },\n  \"highlightSkills\": [],\n  \"missingSkills\": [],\n  \"reason\": \"loaded_from_cache\"\n}",
        "options": {}
      },
      "id": "node-resp-cache",
      "name": "Response Cache",
