        "conditions": {
          "and": [
            {
              "value1": "={{ $json.status }}",
              "operation": "in",
              "value2": "READY,APPLIED"
            }
          ]
        }
      },
      "id": "node-if-cached-valid",
      "name": "IF Cache Valid",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
