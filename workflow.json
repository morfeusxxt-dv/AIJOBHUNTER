      "retryOnFail": true,
      "maxRetries": 3
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={\n  \"apply\": {{ $json.shouldApply }},\n  \"score\": {{ $json.calculatedScore }},\n  \"resumeMarkdown\": \"{{ $json.resumeMarkdown }}\",\n  \"resumeHtml\": \"{{ $json.resumeHtml }}\",\n  \"coverLetter\": \"{{ $json.coverLetter }}\",\n  \"answers\": {\n    \"about\": \"{{ $json.answers.about }}\",\n    \"why\": \"{{ $json.answers.why }}\",\n    \"salary\": \"{{ $json.answers.salary }}\",\n    \"experienceYears\": \"{{ $json.answers.experienceYears || '3' }}\",\n    \"remotePreference\": \"{{ $json.answers.remotePreference || 'Yes' }}\"\n  },\n  \"highlightSkills\": {{ JSON.stringify($json.highlightSkills) }},\n  \"missingSkills\": {{ JSON.stringify($json.missingSkills) }}\n}",
        "options": {}
      },
      "id": "node-webhook-response-24",
      "name": "Enterprise Response",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
        3900,
        500
      ]
    },
    {
      "parameters": {},
