        "operation": "executeQuery",
        "query": "INSERT INTO logs (service, message, level, details, created_at) VALUES ('n8n_workflow', $1, 'INFO', $2, NOW());",
        "additionalFields": {
          "queryParams": "={{ [ 'Enterprise analysis finalized for ' + $('Webhook Reception').item.json.body.title, JSON.stringify($json) ] }}"
        }
      },
      "id": "node-save-workflow-log-23",
