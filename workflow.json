{
  "name": "AI Job Hunter Enterprise Production Workflow",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "job-analysis",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "node-webhook-reception",
      "name": "Webhook Reception",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        100,
        400
      ]
    },
    {
      "parameters": {
        "jsCode": "const body = items[0].json.body || {};\nconst required = ['jobId', 'title', 'company', 'description', 'url'];\nconst missing = required.filter(field => !body[field]);\n\nif (missing.length > 0) {\n  throw new Error(`Missing required fields: ${missing.join(', ')}`);\n}\n\n// Generate robust unique hash using jobId, title, company, url, and a portion of description\nconst descHash = body.description.slice(0, 100).replace(/[^a-zA-Z0-9]/g, '');\nconst hashInput = `${body.jobId}_${body.company}_${body.title}_${body.url}_${descHash}`;\nconst cleanHash = hashInput.replace(/[^a-zA-Z0-9]/g, '_').toLowerCase();\nitems[0].json.jobHash = cleanHash;\n\n// Clean description (remove tags, extra spaces)\nlet cleanDesc = body.description\n  .replace(/<[^>]*>/g, '')\n  .replace(/\\s+/g, ' ')\n  .trim();\nitems[0].json.body.description = cleanDesc;\n\nreturn items;"
      },
      "id": "node-validation-hash",
      "name": "Validation & Hash Generator",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        300,
        400
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT j.id, j.status, j.score, r.file_path as resume_markdown, a.cover_letter FROM jobs j LEFT JOIN resumes r ON r.score = j.score LEFT JOIN applications a ON a.job_id = j.id WHERE j.hash = $1 LIMIT 1;",
        "additionalFields": {
          "queryParams": "={{ [ $json.jobHash ] }}"
        }
      },
      "id": "node-check-duplicate",
      "name": "Check Duplicate DB",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 1,
      "position": [
        500,
        400
      ],
      "onError": "retry",
      "retryOnFail": true,
      "maxRetries": 3
    },
    {
      "parameters": {
        "conditions": {
          "and": [
            {
              "value1": "={{ $json.id }}",
              "operation": "isEmpty"
            }
          ]
        }
      },
      "id": "node-if-dup",
      "name": "IF Not Duplicate",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        700,
        400
